# ═══════════════════════════════════════════════════════════════════════
# Nous · 环境变量模板 / Environment Template
# ───────────────────────────────────────────────────────────────────────
# 复制本文件为 .env.local（开发）或 .env.prod（生产），按需填写。
# Copy to .env.local (dev) or .env.prod (prod), fill in as needed.
# ═══════════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────────────
# 本地 Docker: postgresql://nous:nous@localhost:5432/nous
# 阿里云 RDS: postgresql://<user>:<pass>@<host>:5432/<db>?sslmode=require
DATABASE_URL="postgresql://nous:nous@localhost:5432/nous"

# ── NextAuth ────────────────────────────────────────────────────────────
# 本地开发 http://localhost:3000 · 生产填实际域名
NEXTAUTH_URL="http://localhost:3000"
# openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTES"

# ── 加密 API Key 用 ─────────────────────────────────────────────────────
# openssl rand -hex 32 (必须 64 字符)
CRYPTO_KEY="REPLACE_WITH_64_HEX_CHARS"

# ── 内置 Demo Key（新用户开箱体验）──────────────────────────────────────
# Base URL 可填任何 OpenAI 兼容网关，如浮生云算 https://fushengyunsuan.cn/v1
DEMO_BASE_URL="https://fushengyunsuan.cn/v1"
DEMO_API_KEY="sk-xxx"
DEMO_MODEL="gpt-4o-mini"
DEMO_DAILY_LIMIT=20
DEMO_MAX_TOKENS=2000

# ── Redis（配额 + 限流 + Session 缓存）─────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── 第三方登录（可选）───────────────────────────────────────────────────
# GitHub OAuth: https://github.com/settings/developers
GITHUB_ID=""
GITHUB_SECRET=""

# Google OAuth（可选）
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email Magic Link（可选）─────────────────────────────────────────────
EMAIL_SERVER=""
EMAIL_FROM=""

# ── 站点元数据 ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Nous"
